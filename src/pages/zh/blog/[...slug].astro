---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { formatDate } from '../../../lib/posts';

export const getStaticPaths = (async () => {
  const all = await getCollection('blog');
  const zh = all.filter((p) => p.data.lang === 'zh');
  return zh.map((post) => {
    const hasEn = all.some(
      (p) => p.data.lang === 'en' && p.data.slug === post.data.slug,
    );
    return {
      params: { slug: post.data.slug },
      props: { post, hasEn },
    };
  });
}) satisfies GetStaticPaths;

const { post, hasEn } = Astro.props;
const { Content } = await render(post);

const slug = post.data.slug;
const altUrl = hasEn ? `/blog/${slug}` : undefined;
const alternates = hasEn
  ? [
      { lang: 'en', href: new URL(`/blog/${slug}/`, Astro.site).toString() },
      { lang: 'zh-CN', href: new URL(`/zh/blog/${slug}/`, Astro.site).toString() },
      { lang: 'x-default', href: new URL(`/blog/${slug}/`, Astro.site).toString() },
    ]
  : undefined;
---

<BaseLayout
  lang="zh"
  title={post.data.title}
  description={post.data.summary}
  type="article"
  image={post.data.cover}
  publishedDate={post.data.date}
  updatedDate={post.data.updated}
  altUrl={altUrl}
  alternates={alternates}
>
  <article>
    <header class="article-header">
      <h1>{post.data.title}</h1>
      <span class="meta">
        <time datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date, 'zh')}
        </time>
        {hasEn && (
          <>
            {' · '}
            <a href={`/blog/${slug}`}>Read in English</a>
          </>
        )}
      </span>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>

  <hr />
  <p><a href="/zh/blog">← 返回博客</a></p>
</BaseLayout>

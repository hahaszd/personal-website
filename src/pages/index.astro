---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPosts, formatDate } from '../lib/posts';
import {
  SITE_AUTHOR,
  SITE_AUTHOR_ROMAN,
  SITE_TAGLINE_EN,
  SITE_DESCRIPTION_EN,
} from '../consts';

const posts = await getPosts('en');
const latest = posts.slice(0, 5);

const alternates = [
  { lang: 'en', href: new URL('/', Astro.site).toString() },
  { lang: 'zh-CN', href: new URL('/zh/', Astro.site).toString() },
  { lang: 'x-default', href: new URL('/', Astro.site).toString() },
];
---

<BaseLayout lang="en" altUrl="/zh" alternates={alternates}>
  <section class="hero">
    <p class="tagline">{SITE_TAGLINE_EN}</p>
    <h1>{SITE_AUTHOR_ROMAN}（{SITE_AUTHOR}）</h1>
    <p class="lede">{SITE_DESCRIPTION_EN}</p>
  </section>

  <hr />

  <section>
    <h2>About</h2>
    <p>
      I write about <strong>personal reputation in the AI era</strong>, and I
      think of myself as a <strong>guide / translator for the AI age</strong> —
      making complex AI simple, and helping more people cross the threshold of
      "not knowing what AI can do for them."
    </p>
    <p>
      This site is my own open, indexable home base, where I let long-form
      writing and hands-on project records accumulate. Explainers are an
      amplifier, not a moat — so alongside the "what is it," I anchor everything
      to real practice: what I actually built, the potholes I hit, and my own
      judgment.
    </p>
    <p>
      <a href="/blog">Read the blog →</a>　<a href="/about">More about me →</a>
    </p>
  </section>

  {
    latest.length > 0 && (
      <section>
        <h2>Latest posts</h2>
        <ul class="post-list">
          {latest.map((post) => (
            <li class="post-item">
              <h2>
                <a href={`/blog/${post.data.slug}`}>{post.data.title}</a>
              </h2>
              <span class="meta">
                <time datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date, 'en')}
                </time>
              </span>
              {post.data.summary && <p class="summary">{post.data.summary}</p>}
            </li>
          ))}
        </ul>
        {posts.length > latest.length && (
          <p>
            <a href="/blog">See all {posts.length} posts →</a>
          </p>
        )}
      </section>
    )
  }
</BaseLayout>

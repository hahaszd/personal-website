---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_AUTHOR, SITE_TAGLINE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const latest = posts.slice(0, 5);

const dateFmt = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout>
  <section class="hero">
    <p class="tagline">{SITE_TAGLINE}</p>
    <h1>{SITE_AUTHOR}</h1>
    <p class="lede">{SITE_DESCRIPTION}</p>
  </section>

  <hr />

  <section>
    <h2>关于</h2>
    <p>
      我在围绕「AI 时代的个人品牌」持续输出，自我定位是 AI 时代的向导 /
      翻译者——把复杂的 AI 讲清楚，带更多人跨过「不知道 AI 能做什么」这道认知门槛。
    </p>
    <p>
      这个网站是我自己掌控、开放、可被检索引用的主场：用来沉淀长文与项目实践记录。
      科普是放大器，不是护城河——讲「是什么」的同时，我会挂靠在真实实践上：我真做了什么、踩了什么坑、我的判断。
    </p>
    <p>
      <a href="/blog">读博客 →</a>　<a href="/projects">看项目 →</a>
    </p>
  </section>

  {
    latest.length > 0 && (
      <section>
        <h2>最新文章</h2>
        <ul class="post-list">
          {latest.map((post) => (
            <li class="post-item">
              <h2>
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h2>
              <span class="meta">
                <time datetime={post.data.date.toISOString()}>
                  {dateFmt.format(post.data.date)}
                </time>
              </span>
              {post.data.summary && (
                <p class="summary">{post.data.summary}</p>
              )}
            </li>
          ))}
        </ul>
        {posts.length > latest.length && (
          <p>
            <a href="/blog">查看全部 {posts.length} 篇 →</a>
          </p>
        )}
      </section>
    )
  }
</BaseLayout>

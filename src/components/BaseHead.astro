---
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_AUTHOR,
  SITE_AUTHOR_ROMAN,
  SITE_TAGLINE,
  SAME_AS,
} from '../consts';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** og:type，文章页传 'article' */
  type?: 'website' | 'article';
  image?: string;
  publishedDate?: Date;
  updatedDate?: Date;
  /** 页面语言，用于结构化数据 inLanguage */
  lang?: string;
}

const {
  title,
  description = SITE_DESCRIPTION,
  type = 'website',
  image,
  publishedDate,
  updatedDate,
  lang = 'zh',
} = Astro.props;

const pageTitle = title ? `${title} · ${SITE_TITLE}` : SITE_TITLE;

// 规范链接：依赖 astro.config 的 `site`。
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site) : undefined;
const siteOrigin = Astro.site ? new URL(Astro.site).origin : canonicalURL.origin;
const inLanguage = lang === 'en' ? 'en' : 'zh-CN';

// 作者实体：用稳定的 #person 锚点，便于文章 author 引用同一实体。
const personSchema = {
  '@type': 'Person',
  '@id': `${siteOrigin}/#person`,
  name: SITE_AUTHOR,
  alternateName: SITE_AUTHOR_ROMAN,
  description: SITE_TAGLINE,
  url: `${siteOrigin}/`,
  sameAs: SAME_AS,
};

const websiteSchema = {
  '@type': 'WebSite',
  '@id': `${siteOrigin}/#website`,
  name: SITE_TITLE,
  url: `${siteOrigin}/`,
  inLanguage,
  publisher: { '@id': `${siteOrigin}/#person` },
};

const articleSchema =
  type === 'article'
    ? {
        '@type': 'BlogPosting',
        headline: title,
        description,
        inLanguage,
        ...(publishedDate && { datePublished: publishedDate.toISOString() }),
        ...(updatedDate && { dateModified: updatedDate.toISOString() }),
        ...(ogImage && { image: ogImage.toString() }),
        author: { '@id': `${siteOrigin}/#person` },
        publisher: { '@id': `${siteOrigin}/#person` },
        mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
        url: canonicalURL.toString(),
      }
    : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    personSchema,
    websiteSchema,
    ...(articleSchema ? [articleSchema] : []),
  ],
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<meta name="generator" content={Astro.generator} />

<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={description} />
<meta name="author" content={SITE_AUTHOR} />
<link rel="canonical" href={canonicalURL} />

<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={new URL('rss.xml', Astro.site)}
/>

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="zh_CN" />
{ogImage && <meta property="og:image" content={ogImage} />}
{
  type === 'article' && publishedDate && (
    <meta
      property="article:published_time"
      content={publishedDate.toISOString()}
    />
  )
}
{
  type === 'article' && updatedDate && (
    <meta
      property="article:modified_time"
      content={updatedDate.toISOString()}
    />
  )
}

<!-- Twitter Card -->
<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<!-- 结构化数据 (Schema.org JSON-LD)：给搜索引擎/AI 一个清晰的作者与内容实体 -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />


---
import { SITE_AUTHOR, SITE_AUTHOR_ROMAN, NAV_LINKS_EN, NAV_LINKS_ZH, LANG_SWITCH } from '../consts';

interface Props {
  lang?: 'zh' | 'en';
  /** 语言切换目标 URL（对应的另一语言页面） */
  altUrl?: string;
}

const { lang = 'en', altUrl } = Astro.props;

const nav = lang === 'zh' ? NAV_LINKS_ZH : NAV_LINKS_EN;
const brandHref = lang === 'zh' ? '/zh' : '/';
const brandName = lang === 'zh' ? SITE_AUTHOR : SITE_AUTHOR_ROMAN;
const sw = LANG_SWITCH[lang];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
function isCurrent(href: string) {
  const h = href.replace(/\/$/, '') || '/';
  if (h === '/' || h === '/zh') return pathname === h;
  return pathname === h || pathname.startsWith(h + '/');
}
---

<header class="site-header">
  <div class="container">
    <a class="site-brand" href={brandHref}>{brandName}</a>
    <nav class="site-nav" aria-label="primary">
      {
        nav.map((link) => (
          <a
            href={link.href}
            aria-current={isCurrent(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
      {
        altUrl && (
          <a class="lang-switch" href={altUrl} title={sw.title} hreflang={lang === 'zh' ? 'en' : 'zh'}>
            {sw.label}
          </a>
        )
      }
    </nav>
  </div>
</header>

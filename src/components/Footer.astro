---
import { SITE_AUTHOR, SITE_AUTHOR_ROMAN, SOCIAL_LINKS } from '../consts';

interface Props {
  lang?: 'zh' | 'en';
}
const { lang = 'en' } = Astro.props;
const year = new Date().getFullYear();
const name = lang === 'zh' ? SITE_AUTHOR : SITE_AUTHOR_ROMAN;
const rssHref = lang === 'zh' ? '/zh/rss.xml' : '/rss.xml';
---

<footer class="site-footer">
  <div class="container">
    <span>© {year} {name}</span>
    <span>
      {
        SOCIAL_LINKS.map((link, i) => (
          <>
            {i > 0 && ' · '}
            <a href={link.href} rel="me noopener" target="_blank">
              {link.label}
            </a>
          </>
        ))
      }
      {' · '}
      <a href={rssHref}>RSS</a>
    </span>
  </div>
</footer>

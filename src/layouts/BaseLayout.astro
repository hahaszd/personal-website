---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { DEFAULT_LOCALE } from '../consts';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  image?: string;
  publishedDate?: Date;
  updatedDate?: Date;
  lang?: string;
}

const { lang = DEFAULT_LOCALE, ...head } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead lang={lang} {...head} />
  </head>
  <body>
    <a class="skip-link" href="#main">跳到正文</a>
    <Header />
    <main id="main">
      <div class="container">
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>

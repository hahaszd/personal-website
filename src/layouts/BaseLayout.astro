---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Alternate {
  lang: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  image?: string;
  publishedDate?: Date;
  updatedDate?: Date;
  lang?: 'zh' | 'en';
  /** 语言切换目标 URL */
  altUrl?: string;
  /** hreflang 备选语言链接 */
  alternates?: Alternate[];
}

const {
  lang = 'en',
  altUrl,
  alternates,
  ...head
} = Astro.props;
const skipLabel = lang === 'zh' ? '跳到正文' : 'Skip to content';
---

<!doctype html>
<html lang={lang === 'en' ? 'en' : 'zh-CN'}>
  <head>
    <BaseHead lang={lang} alternates={alternates} {...head} />
  </head>
  <body>
    <a class="skip-link" href="#main">{skipLabel}</a>
    <Header lang={lang} altUrl={altUrl} />
    <main id="main">
      <div class="container">
        <slot />
      </div>
    </main>
    <Footer lang={lang} />
  </body>
</html>
